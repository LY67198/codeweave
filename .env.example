# CodeWeave 环境变量模板
# 复制为 .env 并填入真实值:.env 已在 .gitignore 中,不会推送到远程

# === LLM 配置 (OpenAI 兼容) ===
OPENAI_API_KEY=<your-api-key-here>
OPENAI_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat
MODEL_TEMPERATURE=0.0

# === 数据库 ===
# docker compose 启动 PostgreSQL 后的默认连接
DATABASE_URL=postgresql://codeweave:codeweave_dev@localhost:5432/codeweave

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === 上下文管理 ===
COMPACT_THRESHOLD=32000
COMPACT_ENABLED=true
PLAN_MODE_DEFAULT=true

# === 限制 ===
MAX_REACT_ITERATIONS=8
MAX_REVIEW_ITERATIONS=3
MAX_RECURSION_LIMIT=50

# === 服务端 ===
API_HOST=0.0.0.0
API_PORT=8000
